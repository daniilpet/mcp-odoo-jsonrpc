# Odoo connection (required if not using 'odoo-cli login')
ODOO_BASE_URL=https://odoo.example.com
ODOO_SESSION_ID=your_session_id_here
ODOO_UID=1
ODOO_EMPLOYEE_ID=1
ODOO_COMPANY_IDS=1

# Security (optional)
ODOO_TRUST_MODE=restricted
ODOO_ALLOWED_PROJECTS=

# Locale (optional)
ODOO_LANG=ru_RU
ODOO_TZ=Europe/Moscow
